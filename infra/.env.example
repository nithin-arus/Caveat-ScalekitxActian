# Caveat environment template.
# Copy into the runtime environment on hackathon day. Do not commit real secrets.

NODE_ENV=development

# App
CAVEAT_APP_URL=http://localhost:3000
CAVEAT_DEMO_USER_ID=demo-user-tejas
CAVEAT_DATA_DIR=../data
CAVEAT_GENERATED_DIR=../data/generated
CAVEAT_QUEUE_FILE=../data/generated/watch_jobs.jsonl
CAVEAT_RESULTS_FILE=../data/generated/worker_results.json

# Scalekit - fill when sponsor credentials are available
SCALEKIT_ENV_URL=
SCALEKIT_ENVIRONMENT_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
SCALEKIT_DEFAULT_CONNECTIONS=gmail,googledrive
SCALEKIT_READ_ONLY_SCOPE=openid,profile,email,read
SCALEKIT_ACT_SCOPE=openid,profile,email,read,send

# Actian VectorAI DB - local defaults match the hackathon guide
ACTIAN_IMAGE=actian/vectorai:latest
ACTIAN_VECTORAI_ACCEPT_EULA=YES
ACTIAN_HOST=localhost
ACTIAN_PORT=6574
ACTIAN_URL=localhost:6574
ACTIAN_VECTOR_DIMENSIONS=384
ACTIAN_PLAYBOOK_COLLECTION=clause_playbook

# Render Key Value / Redis-compatible queue
REDIS_URL=redis://localhost:6379

# LLM - optional before event, required for live reasoning
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cron watcher
WATCH_POLL_LIMIT=10
WATCH_MOCK_INBOX=../cron/mock_inbox.json
WATCH_DRY_RUN=true

# Future integration prep
NOTIFICATIONS_PROVIDER=
NOTIFICATIONS_FROM=
